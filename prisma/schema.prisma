generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                    String          @id @default(uuid())
  name                  String
  email                 String          @unique
  password              String?
  role                  Role            @default(USER)
  isDisabled            Boolean         @default(false)
  isEmailVerified       Boolean         @default(false)
  totpSecret            String?
  totpEnabled           Boolean         @default(false)
  lastLoginAttemptAt    DateTime?
  lastSuccessfulLoginAt DateTime?
  createdAt             DateTime        @default(now())
  lastModifiedAt        DateTime        @updatedAt
  actionTokens          ActionToken[]
  brokerAccounts        BrokerAccount[]
  ledger                Ledger[]
  notifications         Notification[]
  tickets               Ticket[]        @relation("TicketCreator")
}

model BrokerAccount {
  id             String    @id @default(uuid())
  userId         String
  mt5AccountNo   String    @unique
  status         Status    @default(PENDING)
  isActive       Boolean   @default(true)
  verifiedAt     DateTime?
  createdAt      DateTime  @default(now())
  lastModifiedAt DateTime  @updatedAt
  user           User      @relation(fields: [userId], references: [id])
}

model Ledger {
  id             String    @id @default(uuid())
  userId         String
  amount         BigInt
  type           EntryType
  category       Category
  referenceId    String?   @unique
  createdAt      DateTime  @default(now())
  lastModifiedAt DateTime  @updatedAt
  user           User      @relation(fields: [userId], references: [id])
}

model Ticket {
  id             String       @id @default(uuid())
  userId         String
  assigneeUserId String?
  type           TicketType
  status         TicketStatus @default(PENDING)
  content        String
  metadata       Json?
  createdAt      DateTime     @default(now())
  lastModifiedAt DateTime     @updatedAt
  closedAt       DateTime?
  user           User         @relation("TicketCreator", fields: [userId], references: [id])
}

model ActionToken {
  id         String          @id @default(uuid())
  userId     String
  tokenType  ActionTokenType
  token      String
  expiresAt  DateTime
  createdAt  DateTime        @default(now())
  consumedAt DateTime?
  user       User            @relation(fields: [userId], references: [id])
}

model Notification {
  id             String   @id @default(uuid())
  userId         String
  message        String
  read           Boolean  @default(false)
  createdAt      DateTime @default(now())
  lastModifiedAt DateTime @updatedAt
  user           User     @relation(fields: [userId], references: [id])
}

enum Role {
  USER
  ADMIN
}

enum Status {
  PENDING
  VERIFIED
}

enum EntryType {
  CREDIT
  DEBIT
}

enum Category {
  REBATE
  WITHDRAWAL
  FEE
}

enum TicketType {
  WITHDRAWAL
  VERIFICATION
}

enum TicketStatus {
  PENDING
  DONE
}

enum ActionTokenType {
  EMAIL_VERIFICATION
  PASSWORD_RESET
}
